{
  "name": "whisperbox-server",
  "version": "1.0.0",
  "description": "High-performance E2EE messaging backend",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "db:init": "npx prisma generate && npx prisma db push",
    "db:reset": "npx prisma db push --force-reset && npx prisma generate",
    "db:seed": "node scripts/seed.js",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/websocket": "^11.0.1",
    "@prisma/client": "^6.2.1",
    "bcryptjs": "^3.0.0",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.2.1"
  }
}
